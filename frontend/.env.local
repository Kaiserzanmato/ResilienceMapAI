# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" or "false" to enable/disable platform features.
# High-risk layers (conflict, aviation, maritime) remain disabled until connectors are validated.

NEXT_PUBLIC_ENABLE_GLOBAL_SOURCE_REGISTRY=true
NEXT_PUBLIC_ENABLE_SOURCE_AUTO_SYNC=true
NEXT_PUBLIC_ENABLE_SOURCE_HEALTH_MONITORING=true
NEXT_PUBLIC_ENABLE_SYNC_AUDIT_LOGS=true

NEXT_PUBLIC_ENABLE_CONFLICT_SECURITY_LAYER=false
NEXT_PUBLIC_ENABLE_HUMANITARIAN_LAYER=true
NEXT_PUBLIC_ENABLE_AVIATION_LAYER=false
NEXT_PUBLIC_ENABLE_MARITIME_LAYER=false

NEXT_PUBLIC_ENABLE_CONFLICT_SECURITY_SYNC=false
NEXT_PUBLIC_ENABLE_HUMANITARIAN_SYNC=true
NEXT_PUBLIC_ENABLE_AVIATION_SYNC=false
NEXT_PUBLIC_ENABLE_MARITIME_SYNC=false

NEXT_PUBLIC_ENABLE_DEEPSEEK_GROUNDED_CONTEXT=true
NEXT_PUBLIC_ENABLE_HOME_GLOBE_LOADER=true
