# ResilienceMap AI — backend environment
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- AI providers (all optional; deterministic local fallback used when unset)
# Alibaba Cloud Qwen (DashScope OpenAI-compatible mode)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Xiaomi MiMo
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-7b-rl

# Optional: OpenAI / Gemini
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Rate limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW=60
AI_RATE_LIMIT_REQUESTS=20

# --- Production infrastructure (schema-ready; MVP runs on curated sample data)
DATABASE_URL=
REDIS_URL=
